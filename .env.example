# Agent Workspace Environment Variables
# Copy this file to .env and fill in the values for services you use.
# All variables are OPTIONAL — only configure the services you need.

# ============================================================
# GOOGLE SERVICES: Gmail, Analytics, Sheets, Drive, BigQuery, Ads, Search Console
# ============================================================
# Run: deno run --allow-all .claude/skills/google/scripts/google.ts
# to authenticate with OAuth (loopback flow — opens browser automatically)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# BIGQUERY_PROJECT=
# GOOGLE_ADS_CUSTOMER_ID=
# GOOGLE_ADS_DEVELOPER_TOKEN=

# ============================================================
# E-COMMERCE: Shopify
# ============================================================
# Get token: Shopify Admin → Settings → Apps → Develop apps → Create → Install
# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# SHOPIFY_API_TOKEN=

# ============================================================
# EMAIL/SMS MARKETING: Klaviyo
# ============================================================
# Get key: Klaviyo → Settings → API Keys → Create Private API Key
# KLAVIYO_PRIVATE_KEY=

# ============================================================
# WORKSPACE: Notion
# ============================================================
# Create integration: notion.so/my-integrations → New integration → Copy token
# Then share relevant pages/databases with the integration
# NOTION_API_TOKEN=

# ============================================================
# ACCOUNTING: QuickBooks
# ============================================================
# Create app: developer.intuit.com → Create → OAuth flow
# Run: deno run --allow-all .claude/skills/quickbooks/scripts/qbo-client.ts auth
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=
# QUICKBOOKS_REALM_ID=
# QUICKBOOKS_REFRESH_TOKEN=
# QUICKBOOKS_ENVIRONMENT=production

# ============================================================
# CUSTOMER SUPPORT: Gorgias
# ============================================================
# Get credentials: Gorgias → Settings → REST API
# GORGIAS_DOMAIN=
# GORGIAS_EMAIL=
# GORGIAS_API_TOKEN=

# ============================================================
# SOCIAL: Instagram / Meta
# ============================================================
# Get token: Meta Developer portal → Create app → Instagram Graph API
# INSTAGRAM_ACCESS_TOKEN=
# FACEBOOK_ACCESS_TOKEN=

# ============================================================
# ADVERTISING: Meta Ads
# ============================================================
# Get token: Meta Business Suite → Business Settings → System Users
# META_ACCESS_TOKEN=
# META_AD_ACCOUNT_ID=

# ============================================================
# SOCIAL: Pinterest
# ============================================================
# Run: deno run --allow-all .claude/skills/pinterest/scripts/pinterest-client.ts auth
# PINTEREST_CLIENT_ID=
# PINTEREST_CLIENT_SECRET=
# PINTEREST_ACCESS_TOKEN=
# PINTEREST_REFRESH_TOKEN=

# ============================================================
# DIGITAL ASSETS: Air.inc
# ============================================================
# Get key: Air.inc → Settings → API → Generate key
# AIR_API_KEY=
# AIR_WORKSPACE_ID=

# ============================================================
# DATABASE: PostgreSQL
# ============================================================
# Connection details from your database host (Supabase, Railway, Neon, etc.)
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_HOST=
# POSTGRES_DATABASE=

# ============================================================
# AI: Claude and Gemini
# ============================================================
# Get key: console.anthropic.com → Settings → API Keys → Create Key
# ANTHROPIC_API_KEY=
# Get key: aistudio.google.com → Get API key → Create key
# GEMINI_API_KEY=
